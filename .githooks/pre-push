#!/usr/bin/env bash
# Mirrors .github/workflows/ci.yml so a red tree is caught here, not in CI.
# Both run `make gate` — the single source of truth for the gate commands.
# Enable once per clone: git config core.hooksPath .githooks
# Emergency bypass: git push --no-verify
set -euo pipefail

# Git hooks run with a minimal PATH that often omits Cargo's bin dir, which
# would make cargo itself (and installed tools) look missing on rustup setups.
export PATH="${CARGO_HOME:-$HOME/.cargo}/bin:$PATH"

# Run from the repo root so `make` finds the Makefile regardless of $GIT_DIR.
exec make -C "$(git rev-parse --show-toplevel)" gate
